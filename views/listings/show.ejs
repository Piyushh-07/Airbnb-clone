<% layout("layouts/boilerplate") %>

<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8">

      <div class="card shadow-sm">
        <h3 class="card-header"><%= listing.title %></h3>
        <img
          src="<%= listing.image %>"
          class="card-img-top show-img"
          alt="Image of <%= listing.title %>"
          style="height: 300px; object-fit: cover;"
        />

        <div class="card-body">
          <p class="card-text mb-2">
            <%= listing.description %><br />
            <strong>&#8377; <%= listing.price.toLocaleString("en-IN") %></strong><br />
            <small class="text-muted"><%= listing.location %>, <%= listing.country %></small>
          </p>

          <div class="d-flex gap-2 mb-3">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
              Edit Listing
            </a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger">Delete Listing</button>
            </form>
          </div>

          <hr>

          <div class="mb-3">
            <h4>Leave a Review</h4>
            <form 
              action="/listings/<%= listing._id %>/reviews" 
              method="POST" 
              novalidate 
              class="needs-validation"
            >
              <div class="mb-3">
           <label for="rating" class="form-label">
            Rating: <span id="ratingValue">3</span>
            </label>
           <input 
            type="range" 
            min="1" 
            max="5" 
            value="3"
            id="rating" 
            name="review[rating]" 
            class="form-range"
            required
            oninput="document.getElementById('ratingValue').innerText = this.value"
            >
</div>

              <div class="mb-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea 
                  name="review[comment]" 
                  id="comment" 
                  cols="50" 
                  rows="5" 
                  class="form-control" 
                  placeholder="Write your review here..."
                  required
                ></textarea>
                <div class="invalid-feedback">
                  Please enter a comment for review.
                </div>
              </div>

              <button class="btn btn-primary mt-2">Submit Review</button>
              </form> 
              <hr/>
              <p><strong>All Reviews</strong></p>
                <div class="reviews-grid">
                <% for(review of listing.reviews) {%>
                      <div class="review-card">
                          <p class="review-comment"><%= review.comment %></p>
                          <p class="review-rating"><strong>Rating: </strong><%= review.rating %></p>
                                               
                        <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                          <button class="btn btn-sm btn-dark">Delete</button>
                        </form>  </div>                  
                <% } %>
              </div>
              </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>